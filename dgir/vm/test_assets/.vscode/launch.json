    "version": "0.2.0",
    "configurations": [
        {
            "type": "dgir",
            "name": "Debug DGIR Program",
            "request": "launch",
            "program": "${workspaceFolder}/HelloWorld.json",
            "dapPort": 4711,
            "jarPath": "${workspaceFolder}/../build/libs/dgir-vm-dap.jar",
            "stopOnEntry": true,
            "useTerminal": true,
            "stopServerOnExit": true,
            "internalConsoleOptions": "neverOpen",
            "autoBasenameSourceMap": true
        }
    ]
}